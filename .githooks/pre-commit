#!/bin/sh
# Bible dual-home guard (pre-commit).
# Mirrors this repo's .claude/ bible skills + agents out to ~/.claude/ so the
# two copies never drift. The repo copy you are committing is canonical.
#
# Cross-platform: runs under Git Bash (Windows), WSL, macOS, Linux.
# NEVER blocks a commit - a sync failure must not stop you committing.

root="$(git rev-parse --show-toplevel)"
guard="$root/.claude/skills/_bible_dual_home_guard/guard.py"

# Nothing to do if the guard script isn't present.
[ -f "$guard" ] || exit 0

# Pick a REAL Python. On Windows the 'py' launcher is the reliable one; the bare
# `python3`/`python` names are often a Microsoft Store stub (a WindowsApps shim
# that only prints an "install from the Store" message and exits non-zero), so
# skip anything that resolves under WindowsApps.
PY=""
if command -v py >/dev/null 2>&1; then
  PY="py -3"
else
  for c in python3 python; do
    p="$(command -v "$c" 2>/dev/null)" || continue
    case "$p" in *[Ww]indows[Aa]pps*) continue ;; esac
    PY="$c"
    break
  done
fi

if [ -z "$PY" ]; then
  echo "[bible-dual-home-guard] no real python found - skipping ~/.claude sync"
  exit 0
fi

$PY "$guard" || true
exit 0
